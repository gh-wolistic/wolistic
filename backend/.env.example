APP_NAME=backend
ENVIRONMENT=development
API_V1_STR=/api/v1

# Comma-separated list
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://rbbomxwgtjlziifkqkyv.supabase.co

# Supabase project URL (for SDKs, callbacks, and cross-origin allow-listing)
SUPABASE_URL=https://rbbomxwgtjlziifkqkyv.supabase.co
SUPABASE_ANON_KEY=replace_me

# Supabase Postgres (transaction pooler URI recommended for app workloads)
# Example: postgresql+asyncpg://postgres.<project_ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?ssl=require
DATABASE_URL=postgresql+asyncpg://postgres:replace_me@db.rbbomxwgtjlziifkqkyv.supabase.co:5432/postgres?ssl=require

# Payment provider
PAYMENT_PROVIDER=mock
PAYMENT_MOCK_DEFAULT_STATUS=success
RAZORPAY_KEY_ID=replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=replace_me
